@startuml seq_getCar

skinparam {
    defaultFontName Source Code Pro
    defaultFontSize 18
    shadowing false
    componentStyle uml2
    MinClassWidth 150
    ParticipantPadding 80
    ArrowThickness 1.5
}

actor "**User**" as User
participant "**Cars Router**" as CR               #98FB98
participant "**Cars Controller**" as CC           #FFD700
participant "**Car Model**" as CM                 #87CEEB
database "**MongoDB**" as DB                      #FFDEAD

== Get car by ID ==

User -> CR: GET /api/cars/:id
activate User                                     #D3D3D3
activate CR                                       #98FB98
CR -> CC: getCar
activate CC                                       #FFD700
CC -> CM: Car.findById(id).populate(provider).populate(bookings)
activate CM                                       #87CEEB
CM --> DB: Query car by id (+provider, +bookings)
activate DB                                       #FFDEAD
DB --> CM: car / null
deactivate DB
CM --> CC: car / null
deactivate CM
CC -> User: 200 OK / 404 Not Found
deactivate CC
deactivate CR
deactivate User

@enduml
