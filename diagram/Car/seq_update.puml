@startuml seq_updateCar

skinparam {
    defaultFontName Source Code Pro
    defaultFontSize 18
    shadowing false
    componentStyle uml2
    MinClassWidth 150
    ParticipantPadding 80
    ArrowThickness 1.5
}

actor "**User**" as User
participant "**Cars Router**" as CR               #98FB98
participant "**Auth Middleware**" as AM           #FF6347
participant "**Cars Controller**" as CC           #FFD700
participant "**Car Model**" as CM                 #87CEEB
database "**MongoDB**" as DB                      #FFDEAD

== Update car (Admin only) ==

User -> CR: PUT /api/cars/:id
activate User                                     #D3D3D3
activate CR                                       #98FB98
CR -> AM: protect, authorize('admin')
activate AM                                       #FF6347
AM -> CC: updateCar
activate CC                                       #FFD700
CC -> CM: Car.findByIdAndUpdate(id, body)
activate CM                                       #87CEEB
CM --> DB: UPDATE car
activate DB                                       #FFDEAD
DB --> CM: updated car / null
deactivate DB
CM --> CC: updated car / null
deactivate CM
CC -> User: 200 OK / 404 Not Found
deactivate CC
deactivate AM
deactivate CR
deactivate User

@enduml
