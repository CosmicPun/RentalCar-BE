@startuml seq_updateProvider

skinparam {
    defaultFontName Source Code Pro
    defaultFontSize 18
    shadowing false
    componentStyle uml2
    MinClassWidth 150
    ParticipantPadding 80
    ArrowThickness 1.5
}

actor "**User**" as User
participant "**Providers Router**" as PR          #98FB98
participant "**Auth Middleware**" as AM           #FF6347
participant "**Providers Controller**" as PC      #FFD700
participant "**Provider Model**" as PM            #87CEEB
database "**MongoDB**" as DB                      #FFDEAD

== Update provider (Admin only) ==

User -> PR: PUT /api/providers/:id
activate User                                     #D3D3D3
activate PR                                       #98FB98
PR -> AM: protect, authorize('admin')
activate AM                                       #FF6347
AM -> PC: updateProvider
activate PC                                       #FFD700
PC -> PM: Provider.findByIdAndUpdate(id, body)
activate PM                                       #87CEEB
PM --> DB: UPDATE provider
activate DB                                       #FFDEAD
DB --> PM: updated provider / null
deactivate DB
PM --> PC: updated provider / null
deactivate PM
PC -> User: 200 OK / 404 Not Found
deactivate PC
deactivate AM
deactivate PR
deactivate User

@enduml
