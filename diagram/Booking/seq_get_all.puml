@startuml seq_getBookings

skinparam {
    defaultFontName Source Code Pro
    defaultFontSize 18
    shadowing false
    componentStyle uml2
    MinClassWidth 150
    ParticipantPadding 80
    ArrowThickness 1.5
}

actor "**User**" as User
participant "**Bookings Router**" as BR           #98FB98
participant "**Auth Middleware**" as AM           #FF6347
participant "**Bookings Controller**" as BC       #FFD700
participant "**Booking Model**" as BM             #87CEEB
database "**MongoDB**" as DB                      #FFDEAD

== Get bookings (my bookings or admin/all) ==

User -> BR: GET /api/bookings
activate User                                     #D3D3D3
activate BR                                       #98FB98
BR -> AM: protect
activate AM                                       #FF6347
AM -> BC: getBookings
activate BC                                       #FFD700
BC -> BM: Booking.find(...) + populate(car->provider)
activate BM                                       #87CEEB
BM --> DB: Query bookings (filtered by role/params)
activate DB                                       #FFDEAD
DB --> BM: bookings[]
deactivate DB
BM --> BC: bookings[]
deactivate BM
BC -> User: 200 OK
deactivate BC
deactivate AM
deactivate BR
deactivate User

@enduml
