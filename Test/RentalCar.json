        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"TOKEN\", \"\");"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{URL}}/api/auth/logout",
              "host": [
                "{{URL}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
