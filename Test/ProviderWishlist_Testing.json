  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('RUN_SUFFIX')) {",
          "  const suffix = Date.now().toString();",
          "  pm.collectionVariables.set('RUN_SUFFIX', suffix);",
          "  pm.collectionVariables.set('ADMIN_EMAIL', `provider-wishlist.admin.${suffix}@example.com`);",
          "  pm.collectionVariables.set('USER_EMAIL', `provider-wishlist.user.${suffix}@example.com`);",
          "  pm.collectionVariables.set('USER2_EMAIL', `provider-wishlist.user2.${suffix}@example.com`);",
          "}"
        ]
      }
    }
  ],
