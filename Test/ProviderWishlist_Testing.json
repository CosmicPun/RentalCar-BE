    {
      "name": "Get Providers As Authenticated User With Wishlist",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{USER_TOKEN}}"
          }
        ],
        "url": {
          "raw": "{{URL}}/api/providers?name[in]=Provider Wishlist A {{RUN_SUFFIX}},Provider Wishlist B {{RUN_SUFFIX}}&sort=name",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "providers"
          ],
          "query": [
            {
              "key": "name[in]",
              "value": "Provider Wishlist A {{RUN_SUFFIX}},Provider Wishlist B {{RUN_SUFFIX}}"
            },
            {
              "key": "sort",
              "value": "name"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Authenticated provider list succeeds', () => pm.response.to.have.status(200));",
              "const providers = pm.response.json().data;",
              "const byId = Object.fromEntries(providers.map((provider) => [provider._id, provider]));",
              "pm.test('Wishlisted flags are correct', () => {",
              "  pm.expect(byId['{{PROVIDER_A_ID}}'].wishlisted).to.eql(true);",
              "  pm.expect(byId['{{PROVIDER_B_ID}}'].wishlisted).to.eql(false);",
              "});"
            ]
          }
        }
      ]
    },
