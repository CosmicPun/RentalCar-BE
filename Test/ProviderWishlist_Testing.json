    {
      "name": "Get Providers As Guest",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{URL}}/api/providers?name[in]=Provider Wishlist A {{RUN_SUFFIX}},Provider Wishlist B {{RUN_SUFFIX}}&sort=name",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "providers"
          ],
          "query": [
            {
              "key": "name[in]",
              "value": "Provider Wishlist A {{RUN_SUFFIX}},Provider Wishlist B {{RUN_SUFFIX}}"
            },
            {
              "key": "sort",
              "value": "name"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Guest provider list succeeds', () => pm.response.to.have.status(200));",
              "const providers = pm.response.json().data;",
              "pm.test('Guest providers expose wishlisted=false', () => {",
              "  pm.expect(providers.length).to.be.greaterThan(0);",
              "  providers.forEach((provider) => {",
              "    pm.expect(provider).to.have.property('wishlisted');",
              "    pm.expect(provider.wishlisted).to.eql(false);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
