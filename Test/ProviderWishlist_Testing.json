    {
      "name": "Get Providers With Pagination And Filter",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{USER_TOKEN}}"
          }
        ],
        "url": {
          "raw": "{{URL}}/api/providers?name[in]=Provider Wishlist A {{RUN_SUFFIX}},Provider Wishlist B {{RUN_SUFFIX}}&sort=name&limit=1&page=1",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "providers"
          ],
          "query": [
            {
              "key": "name[in]",
              "value": "Provider Wishlist A {{RUN_SUFFIX}},Provider Wishlist B {{RUN_SUFFIX}}"
            },
            {
              "key": "sort",
              "value": "name"
            },
            {
              "key": "limit",
              "value": "1"
            },
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Filtered paginated provider list succeeds', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Pagination and wishlisted field remain present', () => {",
              "  pm.expect(body.data.length).to.eql(1);",
              "  pm.expect(body.pagination).to.have.property('next');",
              "  pm.expect(body.data[0]).to.have.property('wishlisted');",
              "});"
            ]
          }
        }
      ]
    }
